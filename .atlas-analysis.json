  "keyFeatures": [
    "Multi-source data ingestion from Reddit, YouTube, Google Play Store, and Apple App Store",
    "LLM-powered feedback classification with Gemini and Ollama support",
    "Automated trend detection and topic spike analysis",
    "Real-time dashboard with sentiment tracking and category breakdown",
    "Scheduled scout runs with APScheduler",
    "RESTful API for programmatic access"
  ],
  "publicApiSurface": [
    "GET /products - List all active products",
    "POST /products - Create a new product",
    "GET /products/{id} - Get product details",
    "GET /products/{id}/summary - Get pulse overview",
    "GET /products/{id}/feedback - List classified feedback",
    "GET /products/{id}/trends - Get trending topics",
    "POST /scout/trigger - Trigger a scout run",
    "GET /scout/runs - List scout run history"
  ]
